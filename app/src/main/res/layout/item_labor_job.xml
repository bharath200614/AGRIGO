<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/tvWorkType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Harvesting"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:fontFamily="sans-serif-bold"/>
            
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 Days"
                android:textSize="12sp"
                android:textColor="#059669"
                android:textStyle="bold"
                android:background="@drawable/bg_card_green_tint"
                android:backgroundTint="#DCFCE7"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvFarmerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Farmer: S. Kumar"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Vidya Jyothi Area"
            android:textSize="13sp"
            android:textColor="#64748B"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <!-- Distance Badge -->
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.5 km away"
                android:textColor="#2563EB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_blue_tint"
                android:backgroundTint="#DBEAFE"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="8dp"/>

            <!-- Workers needed -->
            <TextView
                android:id="@+id/tvWorkersCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3/5 Workers"
                android:textSize="12sp"
                android:textColor="#4F46E5"
                android:textStyle="bold"
                android:background="@drawable/bg_card_blue_tint"
                android:backgroundTint="#E0E7FF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated Pay"
                    android:textSize="12sp"
                    android:textColor="#64748B"/>
                
                <TextView
                    android:id="@+id/tvEstimatedPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹1,200"
                    android:textSize="18sp"
                    android:textColor="#16A34A"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAcceptJob"
                    android:layout_width="140dp"
                    android:layout_height="44dp"
                    android:text="Accept Job"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#16A34A"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRejectJob"
                    android:layout_width="140dp"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#EF4444"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
