<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activities.MachineryBookingActivity">

    <!-- Top Action Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00FFFFFF"
        app:elevation="0dp"
        android:translationZ="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:src="@drawable/ic_back_arrow"
                app:tint="#16A34A"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"/>
                
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Map Background -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="350dp">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Center Map Pin for Draggable Selection -->
        <ImageView
            android:id="@+id/centerPinMarker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            app:tint="#D32F2F"
            android:translationY="-24dp" />
            
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_location"
        app:backgroundTint="@color/white"
        app:tint="#16A34A"
        app:fabSize="normal"
        app:elevation="4dp" />

    <!-- Bottom Sheet Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        app:behavior_hideable="false"
        app:behavior_peekHeight="380dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="@color/card_border"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- 1. Booking Form -->
                <LinearLayout
                    android:id="@+id/layoutBookingForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Work Location"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F0FDF4"
                        app:strokeWidth="1dp"
                        app:strokeColor="#BBF7D0">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_location"
                                app:tint="#16A34A"
                                android:layout_marginEnd="12dp" />
                            <TextView
                                android:id="@+id/tvLocationAddress"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Locating..."
                                android:textColor="#1F2937"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium" />
                            <ProgressBar
                                android:id="@+id/pbLocationProgress"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:indeterminateTint="#16A34A"
                                android:visibility="visible" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Machinery Type Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Machinery Type"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F9FAFB"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E5E7EB">

                        <Spinner
                            android:id="@+id/spinnerMachineryType"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:paddingHorizontal="4dp"
                            android:background="@android:color/transparent"
                            android:spinnerMode="dropdown" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Row for Land Size and Duration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxBackgroundColor="#F9FAFB"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLandSize"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Land Size"
                                android:inputType="numberDecimal"
                                android:paddingVertical="16dp"
                                android:textSize="15sp"
                                android:textColor="#1F2937" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxBackgroundColor="#F9FAFB"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDuration"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Duration"
                                android:inputType="number"
                                android:paddingVertical="16dp"
                                android:textSize="15sp"
                                android:textColor="#1F2937" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Dynamic Price Display - Premium Green Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F0FDF4"
                        app:strokeWidth="1dp"
                        app:strokeColor="#DCFCE7">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="20dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Estimated Price:"
                                android:textColor="#166534"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvEstimatedPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textColor="#16A34A"
                                android:textSize="26sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- 2. Dispatching Mode -->
                <LinearLayout
                    android:id="@+id/layoutDispatching"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="32dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">
                    
                    <ProgressBar
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:indeterminateTint="#16A34A" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Locating nearby providers..."
                        android:textSize="16sp"
                        android:textColor="#1A1D26"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />
                        
                    <TextView
                        android:id="@+id/tvDispatchPayload"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Harvester | 5 Hours | $500"
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="6dp" />
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancelDispatch"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancel Request"
                        android:textColor="#E53935"
                        android:layout_marginTop="24dp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Button Container -->
    <LinearLayout
        android:id="@+id/bottomButtonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnFindMachines"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_margin="20dp"
            android:clickable="true"
            android:focusable="true"
            android:enabled="false"
            app:cardBackgroundColor="#E5E7EB"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvConfirmBtnText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="CONFIRM MACHINERY"
                android:textColor="#9CA3AF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.03" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
