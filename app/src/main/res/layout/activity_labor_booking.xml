<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activities.LaborBookingActivity">

    <!-- Top Action Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00FFFFFF"
        app:elevation="0dp"
        android:translationZ="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_circle_green"
                android:src="@drawable/ic_back_arrow"
                app:tint="#2E7D32"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"/>
                
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Map Background -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="350dp">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Center Map Pin for Draggable Selection -->
        <ImageView
            android:id="@+id/centerPinMarker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            app:tint="#D32F2F"
            android:translationY="-24dp" />
            
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_location"
        app:backgroundTint="@color/white"
        app:tint="#2E7D32"
        app:fabSize="normal"
        app:elevation="4dp" />

    <!-- Bottom Sheet Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        app:behavior_hideable="false"
        app:behavior_peekHeight="380dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="@color/card_border"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- 1. Booking Form -->
                <LinearLayout
                    android:id="@+id/layoutBookingForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Work Location"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E8F5E9"
                        app:strokeWidth="1dp"
                        app:strokeColor="#4CAF50">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_location"
                                app:tint="#2E7D32"
                                android:layout_marginEnd="12dp" />
                            <TextView
                                android:id="@+id/tvLocationAddress"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Locating..."
                                android:textColor="#333333"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <ProgressBar
                                android:id="@+id/pbLocationProgress"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:indeterminateTint="#2E7D32"
                                android:visibility="visible" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Work Type Selection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Work Type"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="4dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="4dp">

                            <LinearLayout
                                android:id="@+id/catLandPrep"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_category_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">
                                <ImageView android:id="@+id/iconLandPrep" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_labor_land_prep" />
                                <TextView android:id="@+id/tvLandPrep" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Land Prep" android:textAlignment="center" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catSowing"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_category_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">
                                <ImageView android:id="@+id/iconSowing" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_labor_sowing" />
                                <TextView android:id="@+id/tvSowing" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sowing" android:textAlignment="center" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catWeeding"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_category_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">
                                <ImageView android:id="@+id/iconWeeding" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_labor_weeding" />
                                <TextView android:id="@+id/tvWeeding" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Weeding" android:textAlignment="center" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catIrrigation"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_category_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">
                                <ImageView android:id="@+id/iconIrrigation" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_labor_irrigation" />
                                <TextView android:id="@+id/tvIrrigation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Irrigation" android:textAlignment="center" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/catHarvesting"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_category_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="8dp">
                                <ImageView android:id="@+id/iconHarvesting" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_labor_harvesting" />
                                <TextView android:id="@+id/tvHarvesting" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Harvesting" android:textAlignment="center" android:textColor="#64748B" android:textSize="11sp" android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Row for Workers and Duration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxBackgroundColor="@color/gray_very_light"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etWorkers"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="No. of Workers"
                                android:inputType="number"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxBackgroundColor="@color/gray_very_light"
                            app:boxStrokeWidth="0dp"
                            app:suffixText="Days"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDuration"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Duration"
                                android:inputType="number"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Dynamic Price Display -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_card_blue_tint"
                        android:backgroundTint="#E8F5E9"
                        android:padding="12dp">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Estimated Price:"
                            android:textColor="#2E7D32"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvEstimatedPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textColor="#2E7D32"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Action Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitRequest"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="CONFIRM LABOR REQUEST"
                        android:textSize="15sp"
                        android:enabled="false"
                        app:icon="@drawable/ic_people"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#2E7D32" />
                </LinearLayout> <!-- booking form -->
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
