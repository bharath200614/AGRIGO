<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Back Arrow -->
            <ImageView
                android:id="@+id/iv_register_logo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="28dp"
                android:src="@drawable/ic_back_arrow"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:contentDescription="Back" />

            <!-- Header -->
            <TextView
                android:id="@+id/tv_register_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Your Role"
                android:textSize="28sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_register_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose how you want to use AgriGo"
                android:textSize="@dimen/text_size_body2"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="32dp" />

            <!-- Role Cards (Reference Match) -->
            <RadioGroup
                android:id="@+id/rg_role"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <!-- Farmer Role Card -->
                <RadioButton
                    android:id="@+id/rb_farmer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:checked="true"
                    android:background="@drawable/bg_role_card_selector"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="🌾  Farmer\nManage your crops and transport"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:drawableEnd="@drawable/ic_check_circle"
                    android:drawableTint="@color/primary_blue"
                    android:elevation="0dp" />

                <!-- Driver Role Card -->
                <RadioButton
                    android:id="@+id/rb_driver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:background="@drawable/bg_role_card_selector"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="🚛  Vehicle Driver\nFind transport requests"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:drawableEnd="@drawable/ic_check_circle"
                    android:drawableTint="@color/primary_blue"
                    android:elevation="0dp" />

                <!-- Labour Role Card -->
                <RadioButton
                    android:id="@+id/rb_labor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:background="@drawable/bg_role_card_selector"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="👷  Labour\nFind daily farm work"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:drawableEnd="@drawable/ic_check_circle"
                    android:drawableTint="@color/primary_blue"
                    android:elevation="0dp" />

                <!-- Machinery Provider Role Card -->
                <RadioButton
                    android:id="@+id/rb_machinery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:background="@drawable/bg_role_card_selector"
                    android:padding="20dp"
                    android:text="🚜  Machinery Provider\nRent out your heavy equipment"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:drawableEnd="@drawable/ic_check_circle"
                    android:drawableTint="@color/primary_blue"
                    android:elevation="0dp" />
            </RadioGroup>

            <!-- Machinery Provider Extras -->
            <LinearLayout
                android:id="@+id/layout_machinery_extras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <!-- Phone Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Phone Number"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/primary_blue"
                    app:boxStrokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingStart="16dp"
                        android:inputType="phone"
                        android:fontFamily="sans-serif"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Machinery Type Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Machinery Type"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/gray_very_light">

                    <Spinner
                        android:id="@+id/spinner_machinery_type"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingHorizontal="12dp"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Driver Extras -->
            <LinearLayout
                android:id="@+id/layout_driver_extras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Type"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/gray_very_light">

                    <Spinner
                        android:id="@+id/spinner_vehicle_type"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingHorizontal="12dp"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Labor Worker Extras -->
            <LinearLayout
                android:id="@+id/layout_labor_extras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <!-- Work Type Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Work Type"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/gray_very_light">

                    <Spinner
                        android:id="@+id/spinner_work_type"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingHorizontal="12dp"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
            <!-- Registration Inputs -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Full Name"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_blue"
                app:boxStrokeWidth="1dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:paddingStart="16dp"
                    android:inputType="textPersonName"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/email_address"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_blue"
                app:boxStrokeWidth="1dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:paddingStart="16dp"
                    android:inputType="textEmailAddress"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="Password"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_blue"
                app:boxStrokeWidth="1dp"
                app:passwordToggleEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:paddingStart="16dp"
                    android:inputType="textPassword"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Register Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register_account"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Create Account"
                app:icon="@drawable/ic_person"
                app:iconGravity="textStart"
                android:background="@drawable/bg_button_blue_ripple"
                android:textColor="@color/white"
                android:fontFamily="sans-serif"
                android:textSize="@dimen/text_size_body1"
                android:textAllCaps="false"
                android:elevation="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Login Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/have_account"
                    android:textSize="@dimen/text_size_body2"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_login_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_here"
                    android:textColor="@color/primary_blue"
                    android:textSize="@dimen/text_size_body2"
                    android:fontFamily="sans-serif"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="4dp" />
            </LinearLayout>

            <!-- Error Message -->
            <TextView
                android:id="@+id/tv_error_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="@color/button_danger"
                android:textSize="@dimen/text_size_body2"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_error_message" />

        </LinearLayout>
    </ScrollView>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/primary_blue" />

</FrameLayout>
