<?xml version="1.0" encoding="utf-8"?>
<!-- Farmer dashboard main layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <!-- Top greeting banner -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/farm_background_farmer_dashboard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_vertical">

            <!-- Greeting text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/greeting_hello"
                        android:textColor="@color/green_dark"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_regular" />

                    <TextView
                        android:id="@+id/tvFarmerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Farmer Name"
                        android:textColor="@color/green_primary"
                        android:textSize="24sp"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Menu button -->
                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_white_stroke"
                    android:src="@drawable/ic_menu"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/menu" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Crop selection section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_crop"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="12dp" />

            <!-- Crop selection grid (2x2) -->
            <GridLayout
                android:id="@+id/cropGridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:columnOrderPreserved="false">

                <!-- Paddy crop card -->
                <FrameLayout
                    android:id="@+id/cropPaddy"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_crop_card"
                    android:tag="paddy">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_crop_paddy"
                            android:contentDescription="@string/crop_paddy" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/crop_paddy"
                            android:textColor="@color/green_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginTop="8dp"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Tomato crop card -->
                <FrameLayout
                    android:id="@+id/cropTomato"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_crop_card"
                    android:tag="tomato">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_crop_tomato"
                            android:contentDescription="@string/crop_tomato" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/crop_tomato"
                            android:textColor="@color/green_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginTop="8dp"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Banana crop card -->
                <FrameLayout
                    android:id="@+id/cropBanana"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_crop_card"
                    android:tag="banana">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_crop_banana"
                            android:contentDescription="@string/crop_banana" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/crop_banana"
                            android:textColor="@color/green_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginTop="8dp"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Sugarcane crop card -->
                <FrameLayout
                    android:id="@+id/cropSugarcane"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_crop_card"
                    android:tag="sugarcane">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_crop_sugarcane"
                            android:contentDescription="@string/crop_sugarcane" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/crop_sugarcane"
                            android:textColor="@color/green_primary"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginTop="8dp"
                            android:gravity="center" />

                    </LinearLayout>

                </FrameLayout>

            </GridLayout>

            <!-- Weight input section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crop_weight"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Weight input field -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="@string/weight_hint"
                    android:inputType="numberDecimal"
                    android:padding="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp" />

            </FrameLayout>

            <!-- Weight error message -->
            <TextView
                android:id="@+id/tvWeightError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/red_error"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Get vehicle suggestion button -->
            <Button
                android:id="@+id/btnGetSuggestion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/get_vehicle_suggestion"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:background="@drawable/bg_suggestion_button"
                android:stateListAnimator="@null"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Suggested vehicles section -->
            <TextView
                android:id="@+id/tvSuggestedVehicles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/suggested_vehicles"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp" />

            <!-- Vehicle suggestions RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvVehicleSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- Loading progress -->
            <ProgressBar
                android:id="@+id/progressLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
