<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".activities.TrackingActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle_green"
            android:src="@drawable/ic_back_arrow"
            app:tint="#16A34A"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Live Tracking"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginEnd="44dp" />
    </LinearLayout>

    <!-- Map Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/gray_very_light">

        <!-- Real Google Map -->
        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Overlay Navigation Instruction -->
        <LinearLayout
            android:id="@+id/layout_navigation_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_green_tint"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                app:tint="#16A34A"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/text_navigation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Locating Route..."
                android:textSize="12sp"
                android:textColor="#16A34A"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Sheet Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        android:layout_marginTop="-24dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="@color/card_border"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- Status Label -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_green_tint"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_icon_circle_green"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/text_current_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver Accepted"
                    android:textSize="13sp"
                    android:textColor="#16A34A"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Progress Steps (5 steps) -->
            <ProgressBar
                android:id="@+id/progress_status"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="5"
                android:progress="1"
                android:progressTint="#16A34A"
                android:progressBackgroundTint="@color/card_border"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/step_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accepted"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:gravity="start" />

                <TextView
                    android:id="@+id/step_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="To Pickup"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/step_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="OTP"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/step_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="To Drop"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/step_5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Done"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_border"
                android:layout_marginBottom="16dp" />

            <!-- Pickup Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_circle_green" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_location"
                        app:tint="@color/accent_green_icon" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/text_pickup_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retrieving location..."
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab_call_farmer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:srcCompat="@drawable/ic_phone"
                    app:tint="@color/white"
                    app:backgroundTint="#16A34A"
                    app:fabSize="mini"
                    app:elevation="2dp" />
            </LinearLayout>

            <!-- Drop Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_circle_orange" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_dest_marker"
                        app:tint="@color/accent_orange" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/text_drop_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retrieving destination..."
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Cargo Details -->
            <TextView
                android:id="@+id/text_cargo_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Fetching payload details..."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif" />

            <!-- ETA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_circle_green" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_calendar"
                        app:tint="#16A34A" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estimated Time"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/text_eta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculating..."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#16A34A"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- OTP Entry Section (hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_otp_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card_green_tint"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter OTP from Farmer"
                    android:textSize="14sp"
                    android:textColor="#16A34A"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/et_otp"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:hint="4-digit OTP"
                        android:inputType="number"
                        android:maxLength="4"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:letterSpacing="0.3"
                        android:background="@drawable/bg_input_rounded"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_verify_otp"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Verify"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        app:cornerRadius="24dp"
                        app:backgroundTint="#16A34A" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_action"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Navigate to Pickup"
                app:icon="@drawable/ic_location"
                app:iconGravity="textStart"
                app:cornerRadius="26dp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif"
                android:textSize="14sp"
                app:backgroundTint="#16A34A" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
