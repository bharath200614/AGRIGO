<?xml version="1.0" encoding="utf-8"?>
<!-- Professional booking card with Rapido/Ola style -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp"
    android:background="@drawable/bg_card"
    android:elevation="@dimen/elevation_medium"
    android:layoutDirection="ltr">

    <!-- Top section: Vehicle info and status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Vehicle icon container -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_green"
            android:alpha="0.1"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/ivVehicleIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_truck"
                android:contentDescription="@string/vehicle"
                android:scaleType="centerInside" />
        </FrameLayout>

        <!-- Vehicle details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <!-- Vehicle type and ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvVehicleType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Standard Truck"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_body1"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:id="@+id/tvBookingId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#B001"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Booking date -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 15, 2024 • 2:30 PM"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Ongoing"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_caption"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_status_ongoing"
            android:paddingHorizontal="12dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Middle section: Crop and weight -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Crop type -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvCropType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paddy"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body1"
                android:fontFamily="@font/poppins_semibold" />
        </LinearLayout>

        <!-- Weight -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1500 kg"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body1"
                android:fontFamily="@font/poppins_semibold" />
        </LinearLayout>

        <!-- Fare -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fare"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹500"
                android:textColor="@color/status_completed"
                android:textSize="@dimen/text_size_body1"
                android:fontFamily="@font/poppins_bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom section: Expandable details -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_light" />

    <LinearLayout
        android:id="@+id/expandedDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/gray_very_light"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pickup location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Pickup"
                    android:layout_marginEnd="12dp"
                    android:scaleType="centerInside" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:fontFamily="@font/poppins_regular" />

                    <TextView
                        android:id="@+id/tvPickupLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Farm No. 5, Green Valley"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body2"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Payment method -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Payment"
                    android:layout_marginEnd="12dp"
                    android:scaleType="centerInside" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:fontFamily="@font/poppins_regular" />

                    <TextView
                        android:id="@+id/tvPaymentMethod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash on Delivery"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_body2"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnTrack"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Track"
                android:textSize="@dimen/text_size_caption"
                android:background="@drawable/bg_button_white_stroke"
                android:textColor="@color/primary_green"
                android:fontFamily="@font/poppins_semibold"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnViewMore"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="More Details"
                android:textSize="@dimen/text_size_caption"
                android:background="@drawable/bg_button_green"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_semibold"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
