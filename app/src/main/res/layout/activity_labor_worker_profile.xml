<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".activities.LaborWorkerProfileActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_card_blue_tint"
            android:backgroundTint="@color/primary_blue_soft"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/primary_blue"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/profile"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginEnd="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp"
            android:gravity="center_horizontal">

            <!-- Profile Avatar -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="28dp">

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_card_blue_tint"
                    android:backgroundTint="@color/primary_blue_soft" />

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="@color/primary_blue" />
            </FrameLayout>


            <!-- Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                android:hint="@string/full_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/primary_blue"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                android:hint="@string/phone_label">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Daily Wage Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:prefixText="₹"
                android:hint="Daily Wage (per day)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editDailyWage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Availability Days -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                android:hint="@string/max_availability">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAvailability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:fontFamily="sans-serif"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Distance Slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="@string/distance_preference"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderDistance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="1.0"
                    android:valueTo="50.0"
                    android:stepSize="1.0"
                    android:value="10.0"
                    app:thumbColor="@color/primary_blue"
                    app:trackColorActive="@color/primary_blue" />

                <TextView
                    android:id="@+id/txtDistanceValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="10 KM"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Work Type Categories (Multi-select) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="Select Work Skills (Multiple allowed)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="24dp"
                android:alignmentMode="alignMargins">

                <LinearLayout
                    android:id="@+id/catLandPrep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <ImageView android:id="@+id/iconLandPrep" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_tractor" />
                    <TextView android:id="@+id/tvLandPrep" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Land Preparation" android:textAlignment="center" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catSowing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <ImageView android:id="@+id/iconSowing" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_plant" />
                    <TextView android:id="@+id/tvSowing" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sowing/Planting" android:textAlignment="center" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catWeeding"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <ImageView android:id="@+id/iconWeeding" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_leaf" />
                    <TextView android:id="@+id/tvWeeding" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Weeding" android:textAlignment="center" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catIrrigation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <ImageView android:id="@+id/iconIrrigation" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_water_drop" />
                    <TextView android:id="@+id/tvIrrigation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Irrigation" android:textAlignment="center" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catHarvesting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:layout_columnSpan="2"
                    android:background="@drawable/bg_category_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <ImageView android:id="@+id/iconHarvesting" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_wheat" />
                    <TextView android:id="@+id/tvHarvesting" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Harvesting" android:textAlignment="center" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

            </GridLayout>

            <!-- Language Option -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLanguage"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/language_label"
                app:icon="@drawable/ic_language"
                app:iconGravity="textStart"
                app:iconTint="@color/primary_blue"
                app:cornerRadius="16dp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                app:strokeColor="@color/primary_blue"
                android:textColor="@color/text_primary" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save"
                app:icon="@drawable/ic_accept"
                app:iconGravity="textStart"
                app:cornerRadius="16dp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                app:backgroundTint="@color/primary_blue" />

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                android:textColor="@color/button_danger"
                app:strokeColor="@color/button_danger_soft"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
