<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/welcome_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Status Bar Safe Area -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="20dp">

            <!-- Header Section with Logo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingBottom="32dp">

                <!-- Circle Background for Logo -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp">

                    <!-- Green Circle Background -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_button_green_gradient"
                        android:alpha="0.15" />

                    <!-- Logo -->
                    <ImageView
                        android:id="@+id/iv_app_logo"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_agrigo_logo"
                        android:contentDescription="@string/app_name"
                        android:scaleType="centerInside" />
                </FrameLayout>

                <!-- App Name -->
                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="@dimen/text_size_h1"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="8dp" />

                <!-- Tagline -->
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Transport for Smart Farmers"
                    android:textSize="@dimen/text_size_body2"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- Illustration Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="40dp">

                <ImageView
                    android:id="@+id/iv_farmer_truck"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_farmer_truck_welcome"
                    android:contentDescription="@string/farmer_truck_illustration"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <!-- Feature Cards Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="36dp">

                <!-- Feature Card 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_check_green"
                        android:contentDescription="Check"
                        android:layout_marginEnd="16dp"
                        android:scaleType="centerInside" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Matching"
                            android:textSize="@dimen/text_size_body1"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get perfect vehicle for your crop load instantly"
                            android:textSize="@dimen/text_size_caption"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Feature Card 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_track"
                        android:contentDescription="Track"
                        android:layout_marginEnd="16dp"
                        android:scaleType="centerInside" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Real-Time Tracking"
                            android:textSize="@dimen/text_size_body1"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track your shipment live with GPS location"
                            android:textSize="@dimen/text_size_caption"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Feature Card 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_home"
                        android:contentDescription="Trust"
                        android:layout_marginEnd="16dp"
                        android:scaleType="centerInside" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trusted &amp; Reliable"
                            android:textSize="@dimen/text_size_body1"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/poppins_semibold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verified drivers and secure transactions"
                            android:textSize="@dimen/text_size_caption"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="bottom">

        <!-- Get Started Button -->
        <Button
            android:id="@+id/btn_get_started"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/get_started"
            android:background="@drawable/bg_button_green_ripple"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="@dimen/text_size_body1"
            android:textAllCaps="false"
            android:elevation="@dimen/elevation_high"
            android:layout_marginBottom="8dp" />

        <!-- Already have account text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?"
                android:textSize="@dimen/text_size_body2"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textSize="@dimen/text_size_body2"
                android:textColor="@color/primary_green"
                android:fontFamily="@font/poppins_semibold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
