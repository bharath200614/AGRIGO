<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Location Pin Icon -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_location"
        app:tint="@color/primary_blue"
        android:padding="6dp"
        android:background="@drawable/bg_icon_circle_blue" />

    <!-- Market Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvMarketName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Market Name"
            android:textSize="15sp"
            android:textColor="#1A1D26"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tvMarketDistrict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="District"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:fontFamily="sans-serif"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- Distance + Price -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvMarketDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 km"
            android:textSize="12sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tvMarketPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹18,500/Q"
            android:textSize="13sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</LinearLayout>
