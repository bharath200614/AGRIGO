# ==============================================
# AgriGo - Environment Configuration Template
# ==============================================
# Copy this file to local.properties and fill in your actual keys.
# local.properties is gitignored and will NOT be committed.
#
# sdk.dir=C:/path/to/your/Android/Sdk
#
# Google Maps API Key (get from Google Cloud Console)
# MAPS_API_KEY=your_google_maps_api_key_here
#
# ML Prediction API Base URL (Render deployment)
# ML_API_BASE_URL=https://your-ml-api.onrender.com/
#
# ==============================================
# ALSO REQUIRED (not tracked by git):
# ==============================================
# app/google-services.json
#   - Download from Firebase Console > Project Settings > Your Android App
#   - Place in the app/ directory
# ==============================================
